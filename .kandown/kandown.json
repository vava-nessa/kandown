{
  "ui": {
    "language": "en",
    "theme": "dark",
    "skin": "rose",
    "font": "system",
    "background": "solid"
  },
  "agent": {
    "suggestFollowUp": true,
    "maxSuggestions": 2
  },
  "board": {
    "columns": [
      "Backlog",
      "Todo",
      "Doing",
      "Review",
      "Done",
      "archives"
    ],
    "defaultPriority": "P3",
    "defaultOwnerType": "human",
    "columnColors": {
      "backlog": "fuchsia",
      "todo": "cyan",
      "review": "cyan",
      "done": "pink",
      "doing": "amber"
    }
  },
  "fields": {
    "priority": false,
    "assignee": false,
    "tags": false,
    "dueDate": false,
    "ownerType": false,
    "tools": false
  },
  "notifications": {
    "browser": true,
    "sound": true,
    "soundId": "chime",
    "statusChanges": true,
    "taskEdits": true,
    "subtaskCompletions": true,
    "editDebounceMs": 2000
  }
}
