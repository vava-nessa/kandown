{
  "ui": {
    "language": "fr",
    "theme": "light",
    "skin": "kandown",
    "font": "system",
    "background": "solid"
  },
  "agent": {
    "suggestFollowUp": true,
    "maxSuggestions": 2
  },
  "board": {
    "columns": [
      "Backlog",
      "Todo",
      "In Progress",
      "Review",
      "Done"
    ],
    "taskPrefix": "task",
    "defaultPriority": "P3",
    "defaultOwnerType": "human",
    "columnColors": {
      "backlog": "fuchsia",
      "todo": "cyan",
      "in progress": "emerald",
      "review": "cyan",
      "done": "pink"
    }
  },
  "fields": {
    "priority": false,
    "assignee": false,
    "tags": false,
    "dueDate": false,
    "ownerType": false,
    "tools": false
  },
  "notifications": {
    "browser": true,
    "sound": true,
    "soundId": "chime",
    "statusChanges": true,
    "taskEdits": true,
    "subtaskCompletions": true,
    "editDebounceMs": 2000
  }
}
