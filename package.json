{
  "name": "kandown",
  "version": "0.3.5",
  "description": "File-based Kanban engine backed by Markdown. Zero backend, AI-agent friendly.",
  "type": "module",
  "bin": {
    "kandown": "bin/kandown.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "kanban",
    "markdown",
    "task-manager",
    "ai-agents",
    "local-first",
    "file-over-app"
  ],
  "author": "Vanessa Depraute (https://github.com/vava-nessa)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vava-nessa/kandown.git"
  },
  "homepage": "https://github.com/vava-nessa/kandown#readme",
  "bugs": {
    "url": "https://github.com/vava-nessa/kandown/issues"
  },
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/sync-agent-kandown.js && vite",
    "dev:cli": "tsup --watch",
    "build": "node scripts/inject-version.js && node scripts/sync-agent-kandown.js && tsc -b && vite build && pnpm build:cli",
    "build:cli": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sync:agent": "node scripts/sync-agent-kandown.js"
  },
  "devDependencies": {
    "@tabler/icons-react": "3.41.1",
    "@types/node": "25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "0.182.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@wysimark/react": "3.0.20",
    "autoprefixer": "^10.4.20",
    "i18next": "26.0.5",
    "ink": "7.0.1",
    "marked": "18.0.2",
    "motion": "^12.38.0",
    "postcss": "^8.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "17.0.4",
    "tailwindcss": "^3.4.17",
    "three": "^0.171.0",
    "tsup": "8.5.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "@blocknote/code-block": "0.49.0",
    "@blocknote/core": "0.49.0",
    "@blocknote/mantine": "0.49.0",
    "@blocknote/react": "0.49.0",
    "@radix-ui/react-slot": "1.2.4",
    "chokidar": "^4.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.8.0",
    "react-devtools-core": ">=6.1.2",
    "signal-exit": "^3.0.7",
    "tailwind-merge": "3.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
