{
  "name": "kandown",
  "version": "0.1.0",
  "description": "File-based Kanban engine backed by Markdown. Zero backend, AI-agent friendly.",
  "type": "module",
  "bin": {
    "kandown": "./bin/kandown.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "kanban",
    "markdown",
    "task-manager",
    "ai-agents",
    "local-first",
    "file-over-app"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:cli": "tsup --watch",
    "build": "tsc -b && vite build && pnpm build:cli",
    "build:cli": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tabler/icons-react": "3.41.1",
    "i18next": "26.0.5",
    "ink": "7.0.1",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "17.0.4",
    "three": "^0.171.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "0.182.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsup": "8.5.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
